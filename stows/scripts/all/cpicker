class HexParser:
    __slots__: tuple[str, ...] = ("_color", "_post", "_pre")
    hex: re.Pattern[str] = re.compile(r"(^.*)?(#[0-9A-Fa-f]{3,12})(.*$)?")

    def __init__(self, text: str | None) -> None:
        self._pre: str | None = None
        self._post: str | None = None
        self._color: Gdk.RGBA | None = None
        if not text or not (match_ := self.hex.match(text)):
            return

        self._pre, color, self._post = match_.groups()
        rgb = Gdk.RGBA()
        if color and rgb.parse(color):
            self._color = rgb

    @property
    def color(self) -> Gdk.RGBA | None:
        return self._color

    def output(self, color: Gdk.RGBA) -> str:
        return f"{self._pre or ''}#{self.rgba_to_hex(color).decode()}{self._post or ''}"

    @staticmethod
    def rgba_to_hex(color: Gdk.RGBA) -> bytes:
        return b16encode(
            bytes((
                round(color.red * 255),
                round(color.green * 255),
                round(color.blue * 255),
            ))
        )

    @staticmethod
    def rgb_to_gdk(rgb: tuple[int, ...]) -> Gdk.RGBA:
        c = Gdk.RGBA()
        c.red = rgb[0] / 255
        c.green = rgb[1] / 255
        c.blue = rgb[2] / 255
        return c

    @staticmethod
    def hex_to_rgb(hexcode: bytes):
        return tuple(map(ord, hexcode[1:].decode("hex")))


class ColorPicker(Gtk.Application):
    def __init__(self, stdin: str | None) -> None:
        super().__init__(
            application_id="org.example.cpicker",
            flags=Gio.ApplicationFlags.FLAGS_NONE,
        )
        self.window: PickerWindow
        self.stdin: str | None = stdin
        self.parser: HexParser

    def do_startup(self):
        """This function is called when the application is first started.

        All initialization should be done here, to prevent doing
        duplicate work in case another window is opened.
        """
        Gtk.Application.do_startup(self)
        self.evk: Gtk.EventControllerKey = Gtk.EventControllerKey()
        self.evk.connect("key-pressed", self.on_key_pressed)

        # FIXME: app don't quit
        action = Gio.SimpleAction.new("quit", None)
        action.connect("activate", self.quit)
        self.add_action(action)

    def do_activate(self) -> None:
        if self.props.active_window:
            self.window.present()
            return

        self.parser = HexParser(self.stdin)
        self.window = PickerWindow(self.parser.color)
        self.window.set_application(self)
        self.window.add_controller(self.evk)
        self.window.present()

    def quit(self) -> None:
        for window in self.get_windows():
            window.destroy()
        super().quit()

    def on_key_pressed(self, _event: Gdk.Event, keyval: int, _keycode: int, _state: int) -> None:
        match keyval:
            case Gdk.KEY_Escape | Gdk.KEY_q:
                self.quit()
                return
            case Gdk.KEY_a | Gdk.KEY_v | Gdk.KEY_p:
                color = self.window.picker.get_rgba()
                sys.stdout.write(f"{self.parser.output(color)}\n")
                self.quit()
            case _:
                return


def read_stdin() -> str | None:
    """Returns input from stdin."""
    if not sys.stdin.isatty():
        with fileinput.input(files="-", mode="r") as _file:
            return "".join(list(_file))
    return None


if __name__ == "__main__":
    app = ColorPicker(stdin=read_stdin())
    sys.exit(app.run(sys.argv))
