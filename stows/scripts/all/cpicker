class PickerWindow(Gtk.ApplicationWindow):
    def __init__(self, color: Gdk.RGBA | None = None) -> None:
        super().__init__(
            decorated=False,
            hide_on_close=True,
            resizable=False,
            focus_visible=False,
            focusable=False,
            sensitive=True,
            visible=True,
        )
        self.set_default_size(300, 300)

        handle = Gtk.WindowHandle()
        self.set_child(handle)

        self.box: Gtk.Box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self.box.set_margin_top(10)
        self.box.set_margin_bottom(10)
        self.box.set_margin_start(10)
        self.box.set_margin_end(10)
        handle.set_child(self.box)

        self.picker: Gtk.ColorChooserWidget = Gtk.ColorChooserWidget()
        self.picker.props.show_editor = True
        if color:
            self.picker.set_rgba(color)
        self.box.append(self.picker)

        # meta = Meta()
