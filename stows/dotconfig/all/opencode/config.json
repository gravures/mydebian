{
    "$schema": "https://opencode.ai/config.json",
    "agent": {
        "build": {
            "permission": {
                "task": {
                    "*": "allow",
                    "tech-leader": "ask",
                    "architect": "ask",
                    "tester": "ask",
                    "tech-writer": "ask",
                    "progress-debbugger": "ask",
                    "product-manager": "deny"
                }
            }
        },
        "plan": {
            "permission": {
                "task": {
                    "tech-leader": "ask",
                    "architect": "ask",
                    "tester": "deny",
                    "tech-writer": "deny",
                    "progress-debbugger": "ask",
                    "product-manager": "deny"
                }
            }
        }
    },
    "lsp": {
        "bash": {
            "command": [ "bash-language-server", "start" ],
            "extensions": [ ".bash", ".sh", ".bob", ".pacstall", ".pacscript" ],
            "initialization": {
                "config": {
                    "backgroundAnalysisMaxFiles": 1,
                    "includeAllWorkspaceSymbols": true
                }
            }
        },
        "pyright": {
            "command": [ "basedpyright-langserver", "--stdio" ],
            "env": { "LC_ALL": "en_US", "LANGUAGE": "en-us", "LANG": "en_US" },
            "initialization": {
                "config": {
                    "basedpyright": {
                        "disableOrganizeImport": true,
                        "analysis": {
                            "diagnosticMode": "openFilesOnly"
                        }
                    }
                }
            },
            "extensions": [ ".py", ".pyw", "ipy" ]
        },
        "ruff": {
            "command": [ "ruff", "server" ],
            "env": { "RUFF_TRACE": "messages" },
            "extensions": [ ".py", ".pyw", "ipy" ]
        },
        "json-lsp": {
            "command": [ "vscode-json-language-server", "--stdio" ],
            "extensions": [ ".json" ],
            "initialization": {
                "config": {
                    "json": {
                        "validate": { "enable": true },
                        "keepLines": { "enanle": true }
                    }
                }
            }
        },
        "yaml-ls": {
            "command": [ "yaml-language-server", "--stdio" ],
            "extensions": [ ".yaml", ".yml" ],
            "initialization": {
                "config": {
                    "yaml": {
                        "validate": { "enable": true },
                        "schema": { "enable": true }
                    }
                }
            }
        },
        "typescript": {
            "command": [ "typescript-language-server", "--stdio" ],
            "extensions": [ ".ts", ".mts", ".cts", ".js", ".jsx", ".mjs", ".cjs" ],
            "initialization": {
                "config": {
                    "hostinfo": "opencode"
                }
            }
        },
        "biome": {
            "command": [ "npm", "exec", "--no", "--", "biome", "lsp-proxy" ],
            "extensions": [ ".ts", ".mts", ".cts", ".js", ".jsx", ".mjs", ".cjs" ]
        },
        "eslint": {
            "disabled": true
        },
        "deno": {
            "disabled": true
        },
        "astro": {
            "command": [ "astro-ls", "--stdio" ],
            "extensions": [ ".astro", ".mdx" ],
            "initialization": {
                "config": {
                    "contentIntellisense": true,
                    "typescript": {
                        "tsdk": "/home/gilles/.nvm/versions/node/v23.7.0/lib/node_modules/typescript/lib",
                        "environment": "node"
                    }
                }
            }
        },
        "somesass": {
            "command": [ "some-sass-language-server", "--stdio" ],
            "extensions": [ ".scss", ".sass", ".css" ],
            "initialization": {
                "config": {
                    "somesass": {
                        "workspace": {
                            "loadPaths": [ "**/*.scss", "**/*.sass" ]
                        }
                    }
                }
            }
        }
    },
    "mcp": {
        "grepai": {
            "type": "local",
            "enabled": true,
            "command": [ "grepai", "mcp-serve" ]
        },
        "astro": {
            "type": "remote",
            "url": "https://mcp.docs.astro.build/mcp",
            "enabled": false
        },
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "enabled": false
        },
        "gh_grep": {
            "type": "remote",
            "url": "https://mcp.grep.app",
            "enabled": false
        }
    },
    "provider": {
        "google": {
            "name": "Google",
            "npm": "@ai-sdk/openai-compatible",
            "api": "https://generativelanguage.googleapis.com/v1beta/openai",
            "models": {
                "gemini-2.5-pro": {
                    "name": "Gemini Pro(Free)",
                    "attachment": false,
                    "temperature": true,
                    "reasoning": true,
                    "tool_call": true,
                    "limit": {
                        "context": 131072,
                        "output": 131072
                    },
                    "modalities": {
                        "input": [ "text" ],
                        "output": [ "text" ]
                    }
                }
            }
        },
        "openrouter": {
            "name": "MyOpenRouter",
            "npm": "@ai-sdk/openai-compatible",
            "api": "https://openrouter.ai/api/v1",
            "models": {
                "z-ai/glm-4.5-air:free": {
                    "name": "Glm-4.5[free]",
                    "options": {
                        "provider": {
                            "only": [ "z-ai" ]
                        }
                    }
                },
                "qwen/qwen3-coder:free": {
                    "name": "Qwen3-Coder[free]",
                    "options": {
                        "provider": {
                            "only": [ "venice/beta" ]
                        }
                    }
                },
                "mistralai/devstral-2512:free": {
                    "name": "Devstral-2[free]"
                }
            }
        },
        "ollama": {
            "npm": "@ai-sdk/openai-compatible",
            "options": {
                "baseURL": "http://127.0.0.1:11434/v1"
            },
            "models": {
                "glm-4.7:cloud": {
                    "name": "glm[free]",
                    "temperature": true,
                    "reasoning": true,
                    "tool_call": true,
                    "limit": {
                        "context": 202752,
                        "output": 65000
                    }
                }
            }
        },
        "llamacpp": {
            "npm": "@ai-sdk/openai-compatible",
            "options": {
                "baseURL": "http://127.0.0.1:9999/v1"
            },
            "models": {
                "ace-coder:7b": {
                    "temperature": false,
                    "reasoning": false,
                    "tool_call": true,
                    "limit": {
                        "context": 8192,
                        "output": 8192
                    }
                },
                "granite3.3:2b": {
                    "name": "granite:2b",
                    "temperature": true,
                    "reasoning": true,
                    "tool_call": true,
                    "limit": {
                        "context": 16384,
                        "output": 16384
                    },
                    "options": {
                        "messages": [
                            { "role": "control", "content": "thinking" }
                        ]
                    }
                },
                "granite-code:3b": {
                    "name": "granite-code:3b",
                    "temperature": true,
                    "reasoning": false,
                    "tool_call": false,
                    "limit": {
                        "context": 8192,
                        "output": 8192
                    },
                    "options": {
                    }
                }
            }
        }
    },
    "autoshare": false,
    "autoupdate": true
}
